{
  "name": "ctx-command-center",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "preinstall": "npm --prefix ../ctx-mqtt install",
    "prestart": "lsof -ti :19471 | xargs kill -9 2>/dev/null || true",
    "start": "tsc -p tsconfig.electron.json && concurrently -k \"vite --config web/vite.config.ts\" \"CTX_VITE=1 electron .\"",
    "start:server": "tsx server/index.ts",
    "dev": "concurrently -k \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "vite --config web/vite.config.ts",
    "build": "npm run build:web && npm run build:server && npm run build:electron",
    "build:web": "vite build --config web/vite.config.ts",
    "build:server": "tsc -p tsconfig.server.json",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:cli": "tsc -p tsconfig.cli.json",
    "package": "npm run build && electron-builder"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@fastify/static": "^8.1.0",
    "@fastify/websocket": "^11.2.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.6.2",
    "ctx-mqtt": "file:../ctx-mqtt",
    "fastify": "^5.2.0",
    "mqtt": "^5.15.0",
    "node-pty": "^1.1.0",
    "openai": "^6.27.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^6.4.0",
    "@mui/material": "^6.4.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "concurrently": "^9.1.0",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^7.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.1.0"
  },
  "main": "dist/electron/main.js",
  "build": {
    "appId": "com.context.desktop",
    "productName": "Context",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
