{
  "name": "ctx-command-center",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "preinstall": "npm --prefix ../ctx-mqtt install",
    "prestart": "lsof -ti :19471 | xargs kill -9 2>/dev/null || true",
    "start": "tsc -p tsconfig.electron.json && electron .",
    "start:server": "tsx server/index.ts",
    "dev": "concurrently -k \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "cd ../../repos/context-ui && npx vite",
    "build": "npm run build:web && npm run build:server && npm run build:electron",
    "build:web": "cd ../../repos/context-ui && npm run build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:cli": "tsc -p tsconfig.cli.json",
    "package": "npm run build && electron-builder"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@fastify/static": "^8.1.0",
    "@fastify/websocket": "^11.2.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@supabase/supabase-js": "^2.99.1",
    "better-sqlite3": "^12.6.2",
    "ctx-mqtt": "file:../ctx-mqtt",
    "cytoscape": "^3.33.1",
    "fastify": "^5.2.0",
    "mqtt": "^5.15.0",
    "node-pty": "^1.1.0",
    "openai": "^6.27.0",
    "react-cytoscapejs": "^2.0.0",
    "react-force-graph-3d": "^1.29.1",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "remark-gfm": "^4.0.1",
    "three": "^0.183.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^6.4.0",
    "@mui/material": "^6.4.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cytoscape": "^3.21.9",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^4.3.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "concurrently": "^9.1.0",
    "electron": "^40.8.2",
    "electron-builder": "^26.8.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^7.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.1.0"
  },
  "main": "dist/electron/main.js",
  "build": {
    "appId": "com.context.desktop",
    "productName": "Context",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
